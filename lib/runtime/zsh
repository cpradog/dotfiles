#!/usr/bin/env bash
ZSH_LOCAL_RC="$(xdg_data_path 'zsh/rc.d')"
ZSH_LOCAL_ENV="$(xdg_data_path 'zsh/env.d')"
ZSH_LOCAL_PROFILE="$(xdg_data_path 'zsh/profile.d')"
ZSH_LOCAL_PLUGINS="$(xdg_data_path 'zsh/plugins')"

function zsh_update_script {
  local type target base_dirs

  type=$1
  [[ "$type" == 'rc'      ]] && target="${D:?}/.zshrc"
  [[ "$type" == 'env'     ]] && target="${D:?}/.zshenv"
  [[ "$type" == 'profile' ]] && target="${D:?}/.zprofile"
  [[ -z "$target"         ]] && die "unknown zsh script $type"

  base_dirs=("${D:?}/$(xdg_config_path "zsh/${type}.d")" "${D:?}/$(xdg_data_path "zsh/${type}.d")")

  info "updating $target..."
  {
    echo "################################################################################"
    echo "##                                                                            ##"
    echo "##                               GENERATED FILE                               ##"
    echo "##                                                                            ##"
    echo "##   Any change to this file will be lost when updated. Please, use the       ##"
    echo "## proper configuration files to change the content and regenerate the file.  ##"
    echo "##                                                                            ##"
    echo "################################################################################"
    echo "#+BEGIN metadata"
    echo "# last updated: $(date -u)"
    echo "# generated by dotfiles package: $PN"
    echo "# generated from:"
    for dir in "${base_dirs[@]}"; do
      echo "#  - $dir"
    done
    echo "#+END metadata"

    while read -r file; do
      echo "#+BEGIN $file"

      if [[ -x "$file" ]]; then
        debug "executing template $file ..."
        "$file"
      else
        debug "adding $file ..."
        cat "$file"
      fi

      echo "#+END $file"
    done < <(find -L "${base_dirs[@]}" -type f -name '*.zsh' -printf '%f\t%p\n' | sort -k1 | cut -d$'\t' -f2)
  } >"$target"
}

function zsh_update_antibody {
  local bindir

  bindir="${D:?}/$(xdg_bin_path '.')"
  mkdir -p "${bindir}"
  curl -sfL git.io/antibody | sh -s - -b "${bindir}"

  info "generating init script ..."
  cat "${D:?}/$(xdg_config_path 'zsh/plugins')" "${D:?}/$ZSH_LOCAL_PLUGINS" |
    "${bindir:?}/antibody" bundle >"${D:?}/${ZSH_LOCAL_RC:?}/00-antibody.zsh"

  zsh_update_script 'rc'
}

function zsh_rc            { link "$1" "${ZSH_LOCAL_RC:?}/${1##*/}";      zsh_update_script 'rc';      }
function zsh_env           { link "$1" "${ZSH_LOCAL_ENV:?}/${1##*/}";     zsh_update_script 'env';     }
function zsh_profile       { link "$1" "${ZSH_LOCAL_PROFILE:?}/${1##*/}"; zsh_update_script 'profile'; }
function zsh_add_plugin    { echo "$1" >>"$ZSH_LOCAL_PLUGINS";            zsh_update_antibody;         }
function zsh_remove_plugin { sed -i "/$1/d" "$ZSH_LOCAL_PLUGINS";         zsh_update_antibody;         }
